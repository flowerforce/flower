{
    "type": "component",
    "name": "FlowerRadio",
    "description": "Radio Component",
    "category": "Flower Form",
    "editing": [
        {
            "type": "Input",
            "id": "id",
            "label": "Field ID"
        },
        {
            "type": "Input",
            "id": "label",
            "label": "Label"
        },
        {
            "type": "List",
            "id": "options",
            "emptyState": "Add an option",
            "item": {
                "children": [
                    {
                        "type": "Input",
                        "id": "label",
                        "label": "Label"
                    },
                    {
                        "type": "Input",
                        "id": "value",
                        "title": "Value"
                    }
                ]
            }
        },
        {
            "type": "Select",
            "id": "align",
            "label": "Align",
            "default": "vertical",
            "options": [
                {
                    "name": "Vertical",
                    "value": "vertical"
                },
                {
                    "name": "Horizontal",
                    "value": "horizontal"
                }
            ]
        },
        {
            "type": "Input",
            "id": "caption",
            "label": "Caption"
        },
        {
            "type": "Rules",
            "id": "rules",
            "label": "Regole di visualizzazione"
        },
        {
            "type": "Switch",
            "id": "isDisabled",
            "default": false,
            "label": "Mostralo disabilitato"
        },
        {
            "type": "Switch",
            "id": "destroyValue",
            "label": "Destroy value on remove field"
        },
        {
            "type": "List",
            "id": "validate",
            "emptyState": "Add a new validation rule",
            "item": {
                "children": [
                    {
                        "type": "Input",
                        "id": "message",
                        "label": "Message"
                    },
                    {
                        "type": "Rules",
                        "id": "rules",
                        "title": "Regole di validazione"
                    }
                ]
            }
        }
    ]
}